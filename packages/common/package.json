{
  "name": "@blockchain/common",
  "version": "1.0.0",
  "private": true,
  "description": "Shared library: logger, errors, kafka, redis, grpc, auth, telemetry, validation",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
