    "@opentelemetry/semantic-conventions": "^1.25.1",
    "bcryptjs": "^2.4.3",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "kafkajs": "^2.2.4",
