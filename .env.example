# =============================================================================
# BlockChain Fintech Platform — Environment Variables
# Copy to `.env` and fill in real values. NEVER commit `.env`.
# =============================================================================

# ---- Runtime ----
NODE_ENV=development
LOG_LEVEL=debug

# ---- Supabase Postgres (one DB, schema per service via ?schema=) ----
# Get connection strings from: Dashboard → Project Settings → Database → Connection string.
# *_DATABASE_URL = Transaction pooler (port 6543, pgbouncer) for app runtime.
# *_DIRECT_URL   = Session pooler (port 5432) for Prisma migrations.
SUPABASE_URL=https://YOUR-PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Replace YOUR-PROJECT (ref), YOUR_DB_PASSWORD and REGION (e.g. us-east-1).
# NOTE: `auth` is reserved by Supabase (GoTrue) — this service uses schema `app_auth`.
AUTH_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=app_auth&pgbouncer=true&connection_limit=1
AUTH_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=app_auth

USER_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=users&pgbouncer=true&connection_limit=1
USER_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=users

WALLET_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=wallets&pgbouncer=true&connection_limit=1
WALLET_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=wallets

BLOCKCHAIN_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=blockchain&pgbouncer=true&connection_limit=1
BLOCKCHAIN_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=blockchain

TRANSACTION_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=transactions&pgbouncer=true&connection_limit=1
TRANSACTION_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=transactions

NOTIFICATION_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=notifications&pgbouncer=true&connection_limit=1
NOTIFICATION_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=notifications

AUDIT_DATABASE_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres?schema=audit&pgbouncer=true&connection_limit=1
AUDIT_DIRECT_URL=postgresql://postgres.YOUR-PROJECT:YOUR_DB_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?schema=audit

# ---- JWT ----
JWT_SECRET=change-me-access-secret-min-32-chars-长
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars
JWT_ACCESS_TTL=900
JWT_REFRESH_TTL=604800
JWT_ISSUER=blockchain-fintech
JWT_AUDIENCE=blockchain-fintech-clients

# ---- Redis ----
REDIS_URL=redis://localhost:6379

# ---- Kafka ----
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=blockchain-fintech
KAFKA_SSL=false

# ---- Supabase Storage (avatar object storage) ----
# Uses the SUPABASE_URL + SUPABASE_SERVICE_ROLE_KEY above (via @supabase/supabase-js).
# Bucket is auto-created (public) on first upload.
SUPABASE_AVATAR_BUCKET=avatars

# ---- gRPC service ports (internal) ----
AUTH_GRPC_ADDR=0.0.0.0:50051
USER_GRPC_ADDR=0.0.0.0:50052
WALLET_GRPC_ADDR=0.0.0.0:50053
BLOCKCHAIN_GRPC_ADDR=0.0.0.0:50054
TRANSACTION_GRPC_ADDR=0.0.0.0:50055
NOTIFICATION_GRPC_ADDR=0.0.0.0:50056
AUDIT_GRPC_ADDR=0.0.0.0:50057

# gRPC targets the gateway/services dial (host:port). In docker-compose use service names.
AUTH_GRPC_TARGET=localhost:50051
USER_GRPC_TARGET=localhost:50052
WALLET_GRPC_TARGET=localhost:50053
BLOCKCHAIN_GRPC_TARGET=localhost:50054
TRANSACTION_GRPC_TARGET=localhost:50055
NOTIFICATION_GRPC_TARGET=localhost:50056
AUDIT_GRPC_TARGET=localhost:50057

# ---- HTTP ports (health/metrics; gateway is the public one) ----
GATEWAY_PORT=4000
AUTH_HTTP_PORT=5051
USER_HTTP_PORT=5052
WALLET_HTTP_PORT=5053
BLOCKCHAIN_HTTP_PORT=5054
TRANSACTION_HTTP_PORT=5055
NOTIFICATION_HTTP_PORT=5056
AUDIT_HTTP_PORT=5057

# ---- Gateway / CORS / Rate limit ----
CORS_ORIGINS=http://localhost:3000
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# ---- Observability ----
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAMESPACE=blockchain-fintech
PROMETHEUS_ENABLED=true

# ---- Blockchain tuning ----
BLOCKCHAIN_DIFFICULTY=4
BLOCKCHAIN_MINING_REWARD=50
BLOCKCHAIN_BLOCK_TX_LIMIT=10

# ---- Frontend (Next.js) ----
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api/v1
